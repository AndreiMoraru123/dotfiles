" ============================================================
" .ideavimrc
" ============================================================

" --- Options ---
set scrolloff=5
set incsearch
set visualbell
set showmode
set ideajoin
set number
set relativenumber

" --- Leader ---
let mapleader = " "

" --- Plugins ---
set textobj-indent
set highlightedyank
set NERDTree
set commentary
set sneak
set multiple-cursors
set surround
set peekaboo
set quickscope
let g:qs_highlight_on_keys = ['f', 'F', 't', 'T']

" ============================================================
" MAPPINGS — all Action mappings MUST use map/nmap/vmap/imap
" ============================================================

" Reload this config
nmap <leader>r <Action>(IdeaVim.ReloadVimRc.reload)

" Show error
map <C-k> <Action>(ShowErrorDescription)

" Accept autocomplete dropdown
imap <C-y> <Action>(EditorChooseLookupItem)

" Reformat
map \r <Action>(ReformatCode)

" Debug
map <leader>d <Action>(Debug)

" Breakpoint
map \b <Action>(ToggleLineBreakpoint)

" Go to next error
nmap <C-e> <Action>(GotoNextError)

" Stop
map <leader>q <Action>(Stop)

" Go to definition
nmap gd <Action>(GotoDeclaration)

" Go to implementation (works with virtual methods, interfaces, etc.)
nmap gi <Action>(GotoImplementation)

" Go to super method
nmap gs <Action>(GotoSuperMethod)

" Find usages
nmap gr <Action>(FindUsages)

" Go to symbol in file (Cmd-T is macos/jetbrains native for universal search, not in file)
nmap gO <Action>(FileStructurePopup)

" Switch between header and source files (C/C++)
nmap gh <Action>(SwitchHeaderSource)

" Code actions (lightbulb)
nmap <C-.> <Action>(ShowIntentionActions)

" --- Safe noremap mappings (no <Action>, so noremap is fine) ---
map Q gq

" Move lines in visual mode
vnoremap J :m '>+1<CR>gv=gv
vnoremap K :m '<-2<CR>gv=gv

" Paste without clobbering register
vnoremap <leader>p "_dP

" Yank to system clipboard
vnoremap <leader>y "+y
nnoremap <leader>y "+y
nnoremap <leader>Y gg"+yG

" Case toggles
nnoremap <Leader>u viwU
nnoremap <Leader>l viwu

" --- Multiple-Cursors ---
" Remap multiple-cursors shortcuts to match terryma/vim-multiple-cursors
nmap <C-n> <Plug>NextWholeOccurrence
xmap <C-n> <Plug>NextWholeOccurrence
nmap g<C-n> <Plug>NextOccurrence
xmap g<C-n> <Plug>NextOccurrence
xmap <C-x> <Plug>SkipOccurrence
xmap <C-p> <Plug>RemoveOccurrence

" Note that the default <A-n> and g<A-n> shortcuts don't work on Mac due to dead keys.
" <A-n> is used to enter accented text e.g. ñ
" Feel free to pick your own mappings that are not affected. I like to use <leader>
nmap <leader><C-n> <Plug>AllWholeOccurrences
xmap <leader><C-n> <Plug>AllWholeOccurrences
nmap <leader>g<C-n> <Plug>AllOccurrences
xmap <leader>g<C-n> <Plug>AllOccurrences
